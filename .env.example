# FaceAuth Production Environment Variables
# Copy this file to .env and fill in your values

# ==================== FLASK ====================
FLASK_SECRET=your-super-secret-key-change-this
PORT=8080

# ==================== DIGITAL OCEAN URL ====================
# Set this to your production URL (no trailing slash)
FACEAUTH_BASE_URL=https://faceauth.yourdomain.com

# ==================== MICROSOFT DATAVERSE ====================
TENANT_ID=your-azure-tenant-id
CLIENT_ID=your-azure-client-id
CLIENT_SECRET=your-azure-client-secret
RESOURCE=https://yourorg.crm.dynamics.com

# ==================== BREVO EMAIL ====================
BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=noreply@yourdomain.com
COMPANY_NAME=Your Company Name
ADMIN_EMAIL=admin@yourdomain.com

# ==================== JWT (MUST MATCH HR TOOL) ====================
JWT_SECRET=shared-secret-with-hr-tool
JWT_SECRET_KEY=shared-secret-with-hr-tool

# ==================== GUNICORN (OPTIONAL) ====================
GUNICORN_WORKERS=3
